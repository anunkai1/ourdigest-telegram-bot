[Unit]
Description=ourdigest-telegram-bot - Telegram bot for ourdigest /news
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User=architect
WorkingDirectory=/home/architect/ourdigest-telegram-bot
EnvironmentFile=/home/architect/ourdigest-telegram-bot/.env
ExecStart=/home/architect/ourdigest-telegram-bot/.venv/bin/ourdigest-telegram-bot
Restart=on-failure
RestartSec=5s
Nice=5

[Install]
WantedBy=multi-user.target
